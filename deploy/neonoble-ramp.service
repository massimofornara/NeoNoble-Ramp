[Unit]
Description=NeoNoble Ramp FastAPI
After=network.target

[Service]
User=ubuntu
Group=ubuntu
WorkingDirectory=/opt/neonoble-ramp
EnvironmentFile=/opt/neonoble-ramp/.env
ExecStart=/usr/bin/python3 -m uvicorn server:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
